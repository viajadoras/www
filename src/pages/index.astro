---
import Base from "../layouts/Base.astro";
import Hero from "../components/hero-section.astro";
import HowItWorks from "../components/how-it-works.astro";
import UseCases from "../components/use-cases.astro";
import FAQ from "../components/FAQ.astro";
import CTASection from "../components/CTASection.astro";

const title =
  "Viajadoras | Companhia confiável para sair mais da rotina";
const description =
  "Comunidade entre mulheres com grupos, conversa e mais contexto para sair mais na sua cidade e viajar com mais confiança.";
---

<Base {title} {description} lang="pt-BR">
  <Hero />

  <HowItWorks />

  <UseCases />

  <FAQ />

  <CTASection />
</Base>

---
import CTASection from '../components/CTASection.astro';
import FAQ from '../components/FAQ.astro';
import Hero from '../components/hero-section.astro';
import HowItWorks from '../components/how-it-works.astro';
import UseCases from '../components/use-cases.astro';
import Base from '../layouts/Base.astro';

const title = 'Viajadoras | Companhia com mais contexto para sair da rotina';
const description =
  'Comunidade entre mulheres com grupos, conversa e mais contexto para sair mais na sua cidade e levar essa rede para viagens.';
---

<Base {title} {description} lang="pt-BR">
  <Hero />

  <HowItWorks />

  <UseCases />

  <FAQ />

  <CTASection />
</Base>

---
const cases = [
  {
    number: '01',
    title: 'Quero sair mais',
    description:
      'Mas quase nada vai para frente.',
    accent: 'border-primary/20 bg-white',
  },
  {
    number: '02',
    title: 'Quero encontrar meu grupo',
    description:
      'Para recomeço, mudança ou rotina travada.',
    accent: 'border-teal-500/20 bg-teal-50/70',
  },
  {
    number: '03',
    title: 'Quero viajar com mais confiança',
    description:
      'Sem depender do acaso para encontrar companhia.',
    accent: 'border-lavender-500/20 bg-lavender-50/60',
  },
];
---

<section id="para-quem" class="bg-neutral-50 py-16 lg:py-20">
  <div class="container mx-auto px-4 sm:px-6 lg:px-8">
    <div class="grid gap-10 lg:grid-cols-[0.78fr_1.22fr] lg:gap-14">
      <div class="lg:pt-4">
        <p class="text-sm font-semibold uppercase tracking-[0.18em] text-primary">
          Para quando faz sentido
        </p>
        <h2 class="mt-4 font-display text-4xl font-bold leading-tight text-neutral-900 sm:text-[3.1rem]">
          Quando falta companhia
          <span class="text-primary"> para as coisas saírem do papel</span>
        </h2>
        <p class="mt-5 max-w-xl text-base leading-relaxed text-neutral-600 sm:text-lg">
          Nem toda mulher chega aqui pensando primeiro em viagem. Muitas chegam
          porque querem voltar a viver mais.
        </p>
      </div>

      <div class="grid gap-4">
        {cases.map((item) => (
          <article class={`rounded-[2rem] border p-6 shadow-sm sm:p-7 ${item.accent}`}>
            <div class="grid gap-4 sm:grid-cols-[auto_1fr] sm:items-start">
              <div class="inline-flex h-10 w-10 items-center justify-center rounded-full bg-neutral-900 text-sm font-semibold text-white">
                {item.number}
              </div>
              <div>
                <h3 class="text-2xl font-bold leading-tight text-neutral-900">
                  {item.title}
                </h3>
                <p class="mt-3 max-w-xl text-base leading-relaxed text-neutral-600 sm:text-lg">
                  {item.description}
                </p>
              </div>
            </div>
          </article>
        ))}
      </div>
    </div>
  </div>
</section>

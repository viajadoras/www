---
// Schema.org FAQPage for rich snippets
const siteUrl = Astro.site?.toString() || 'https://viajadoras.com';

const faqSchema = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: [
    {
      '@type': 'Question',
      name: 'Como funciona o app Viajadoras para mulheres viajantes?',
      acceptedAnswer: {
        '@type': 'Answer',
        text: 'O Viajadoras é um aplicativo que conecta mulheres que querem viajar, conhecer outras mulheres e viver experiências com mais confiança. Você pode participar de comunidades, conversar, descobrir companhia para viajar e fazer parte de uma rede de apoio feminina.'
      }
    },
    {
      '@type': 'Question',
      name: 'O app é só para mulheres viajando sozinhas?',
      acceptedAnswer: {
        '@type': 'Answer',
        text: 'Não. O Viajadoras é para mulheres que viajam sozinhas, acompanhadas, a trabalho, a lazer ou que simplesmente querem ampliar sua rede e criar conexões antes de viajar.'
      }
    },
    {
      '@type': 'Question',
      name: 'É seguro viajar sozinha sendo mulher?',
      acceptedAnswer: {
        '@type': 'Answer',
        text: 'Viajar sozinha pede planejamento, informação e rede de apoio. O Viajadoras existe para ajudar mulheres a criar conexões mais confiáveis, trocar referências e se aproximar de outras viajantes.'
      }
    },
    {
      '@type': 'Question',
      name: 'Como posso encontrar outras mulheres para viajar junto?',
      acceptedAnswer: {
        '@type': 'Answer',
        text: 'No app Viajadoras, você pode participar de comunidades, explorar perfis, conversar com outras mulheres e se aproximar de viajantes com interesses ou planos parecidos.'
      }
    },
    {
      '@type': 'Question',
      name: 'Preciso pagar para usar o Viajadoras?',
      acceptedAnswer: {
        '@type': 'Answer',
        text: 'Não. O Viajadoras está disponível para Android e iPhone, e você também pode acompanhar novidades e conteúdo da comunidade no Instagram @viajadorasbr.'
      }
    }
  ]
};
---

<script type="application/ld+json" set:html={JSON.stringify(faqSchema)} />

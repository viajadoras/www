---
import {
  appStoreUrl,
  company,
  instagramUrl,
  playStoreUrl,
  siteName,
  siteOrigin,
} from '../data/site';

interface Props {
  type?: 'homepage' | 'page';
  title?: string;
  description?: string;
  url?: string;
}

const { type = 'page', title, description, url } = Astro.props;
const origin = (Astro.site?.toString() || siteOrigin).replace(/\/+$/, '');
const siteUrl = `${origin}/`;
const currentUrl = url || Astro.url.toString();

const organizationSchema = {
  '@context': 'https://schema.org',
  '@type': 'Organization',
  '@id': `${origin}/#organization`,
  name: siteName,
  legalName: company.legalName,
  url: siteUrl,
  logo: {
    '@type': 'ImageObject',
    url: `${origin}/logo.png`,
    width: 512,
    height: 512
  },
  image: `${origin}/og_1200x630.jpg`,
  description: 'Comunidade entre mulheres para sair mais da rotina e viajar com mais confiança.',
  address: {
    '@type': 'PostalAddress',
    streetAddress: company.streetAddress,
    addressLocality: company.addressLocality,
    addressRegion: company.addressRegion,
    postalCode: company.postalCode,
    addressCountry: company.addressCountry
  },
  contactPoint: {
    '@type': 'ContactPoint',
    contactType: 'customer support',
    availableLanguage: ['pt-BR']
  },
  sameAs: [
    instagramUrl,
    playStoreUrl,
    appStoreUrl,
  ],
  founder: {
    '@type': 'Organization',
    name: company.legalName
  }
};

const websiteSchema = {
  '@context': 'https://schema.org',
  '@type': 'WebSite',
  '@id': `${origin}/#website`,
  url: siteUrl,
  name: siteName,
  description: 'Comunidade entre mulheres para sair mais da rotina e viajar com mais confiança.',
  publisher: {
    '@id': `${origin}/#organization`
  },
  inLanguage: 'pt-BR'
};

const mobileAppSchemas = [
  {
    '@context': 'https://schema.org',
    '@type': 'MobileApplication',
    name: siteName,
    operatingSystem: 'ANDROID',
    applicationCategory: 'TravelApplication',
    offers: {
      '@type': 'Offer',
      price: '0',
      priceCurrency: 'BRL'
    },
    description: 'Comunidade entre mulheres para participar de grupos e encontrar companhia para a cidade e para viagens.',
    image: `${origin}/logo.png`,
    screenshot: `${origin}/og_1200x630.jpg`,
    url: playStoreUrl,
  },
  {
    '@context': 'https://schema.org',
    '@type': 'MobileApplication',
    name: siteName,
    operatingSystem: 'IOS',
    applicationCategory: 'TravelApplication',
    offers: {
      '@type': 'Offer',
      price: '0',
      priceCurrency: 'BRL'
    },
    description: 'Comunidade entre mulheres para participar de grupos e encontrar companhia para a cidade e para viagens.',
    image: `${origin}/logo.png`,
    screenshot: `${origin}/og_1200x630.jpg`,
    url: appStoreUrl,
  },
];

const webPageSchema = {
  '@context': 'https://schema.org',
  '@type': 'WebPage',
  '@id': currentUrl,
  url: currentUrl,
  name: title || 'Viajadoras - Comunidade entre mulheres para sair mais e viajar com mais confiança',
  description: description || 'Comunidade entre mulheres para sair mais da rotina e viajar com mais confiança.',
  isPartOf: {
    '@id': `${origin}/#website`
  },
  about: {
    '@id': `${origin}/#organization`
  },
  inLanguage: 'pt-BR'
};

const schemas = type === 'homepage'
  ? [organizationSchema, websiteSchema, ...mobileAppSchemas, webPageSchema]
  : [webPageSchema];
---

{schemas.map(schema => (
  <script type="application/ld+json" set:html={JSON.stringify(schema)} />
))}

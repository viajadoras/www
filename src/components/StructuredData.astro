---
interface Props {
  type?: 'homepage' | 'page';
  title?: string;
  description?: string;
  url?: string;
}

const { type = 'page', title, description, url } = Astro.props;
const siteOrigin = (Astro.site?.toString() || 'https://viajadoras.com').replace(/\/+$/, '');
const siteUrl = `${siteOrigin}/`;
const currentUrl = url || Astro.url.toString();
const playStoreUrl = 'https://play.google.com/store/apps/details?id=com.viajadoras.app&pcampaignid=web_share';
const appStoreUrl = 'https://apps.apple.com/br/app/viajadoras/id6755790482';

const organizationSchema = {
  '@context': 'https://schema.org',
  '@type': 'Organization',
  '@id': `${siteOrigin}/#organization`,
  name: 'Viajadoras',
  legalName: 'GT TECNOLOGIA E SERVICOS LTDA',
  url: siteUrl,
  logo: {
    '@type': 'ImageObject',
    url: `${siteOrigin}/logo.png`,
    width: 512,
    height: 512
  },
  image: `${siteOrigin}/og_1200x630.jpg`,
  description: 'Comunidade feminina para conhecer outras mulheres, encontrar companhia para viajar e viver experiências com mais confiança.',
  address: {
    '@type': 'PostalAddress',
    streetAddress: 'Av. Portugal, 1148',
    addressLocality: 'Goiânia',
    addressRegion: 'GO',
    postalCode: '74150-030',
    addressCountry: 'BR'
  },
  contactPoint: {
    '@type': 'ContactPoint',
    contactType: 'customer support',
    availableLanguage: ['pt-BR']
  },
  sameAs: [
    'https://instagram.com/viajadorasbr',
    playStoreUrl,
    appStoreUrl,
  ],
  founder: {
    '@type': 'Organization',
    name: 'GT TECNOLOGIA E SERVICOS LTDA'
  }
};

const websiteSchema = {
  '@context': 'https://schema.org',
  '@type': 'WebSite',
  '@id': `${siteOrigin}/#website`,
  url: siteUrl,
  name: 'Viajadoras',
  description: 'Comunidade feminina para conhecer outras mulheres, encontrar companhia para viajar e viver experiências com mais confiança.',
  publisher: {
    '@id': `${siteOrigin}/#organization`
  },
  inLanguage: 'pt-BR'
};

const mobileAppSchemas = [
  {
    '@context': 'https://schema.org',
    '@type': 'MobileApplication',
    name: 'Viajadoras',
    operatingSystem: 'ANDROID',
    applicationCategory: 'TravelApplication',
    offers: {
      '@type': 'Offer',
      price: '0',
      priceCurrency: 'BRL'
    },
    description: 'Comunidade feminina para conhecer outras mulheres, encontrar companhia para viajar e acessar uma rede de apoio entre viajantes.',
    image: `${siteOrigin}/logo.png`,
    screenshot: `${siteOrigin}/og_1200x630.jpg`,
    url: playStoreUrl,
  },
  {
    '@context': 'https://schema.org',
    '@type': 'MobileApplication',
    name: 'Viajadoras',
    operatingSystem: 'IOS',
    applicationCategory: 'TravelApplication',
    offers: {
      '@type': 'Offer',
      price: '0',
      priceCurrency: 'BRL'
    },
    description: 'Comunidade feminina para conhecer outras mulheres, encontrar companhia para viajar e acessar uma rede de apoio entre viajantes.',
    image: `${siteOrigin}/logo.png`,
    screenshot: `${siteOrigin}/og_1200x630.jpg`,
    url: appStoreUrl,
  },
];

const webPageSchema = {
  '@context': 'https://schema.org',
  '@type': 'WebPage',
  '@id': currentUrl,
  url: currentUrl,
  name: title || 'Viajadoras - Toda mulher. Qualquer viagem.',
  description: description || 'Comunidade feminina para conhecer outras mulheres, encontrar companhia para viajar e viver experiências com mais confiança.',
  isPartOf: {
    '@id': `${siteOrigin}/#website`
  },
  about: {
    '@id': `${siteOrigin}/#organization`
  },
  inLanguage: 'pt-BR'
};

const schemas = type === 'homepage'
  ? [organizationSchema, websiteSchema, ...mobileAppSchemas, webPageSchema]
  : [webPageSchema];
---

{schemas.map(schema => (
  <script type="application/ld+json" set:html={JSON.stringify(schema)} />
))}

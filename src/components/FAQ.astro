---
import { siteFaqs } from '../data/faqs';
---

<section id="faq" class="bg-neutral-50 py-20 lg:py-24">
  <div class="container relative z-10">
    <div class="mx-auto max-w-3xl">
      <div class="mb-14 text-center">
        <p class="text-sm font-semibold uppercase tracking-[0.18em] text-primary">
          FAQ
        </p>
        <h2 class="mt-4 font-display text-4xl font-bold text-neutral-900 md:text-5xl">
          Dúvidas comuns
        </h2>
        <p class="mt-4 text-lg leading-relaxed text-neutral-600">
          Respostas curtas para você entender rápido como o app funciona e se
          ele faz sentido para o seu momento.
        </p>
      </div>

      <div class="space-y-4">
        {siteFaqs.map((faq, index) => (
          <details
            class="faq-item group overflow-hidden rounded-[1.75rem] border border-neutral-200 bg-white shadow-sm transition-all duration-300"
            data-delay={index * 100}
          >
            <summary class="flex list-none cursor-pointer select-none items-start justify-between gap-6 p-6 transition-all duration-300 hover:bg-neutral-50">
              <span class="pr-4 text-lg font-semibold text-neutral-900">
                {faq.question}
              </span>
              <div class="relative mt-0.5 h-8 w-8 flex-shrink-0">
                <div class="icon-plus absolute inset-0 flex items-center justify-center transition-all duration-300 group-open:rotate-45">
                  <svg
                    xmlns="http://www.w3.org/2000/svg"
                    class="h-7 w-7 text-primary"
                    fill="none"
                    viewBox="0 0 24 24"
                    stroke="currentColor"
                    stroke-width="2.5"
                  >
                    <path stroke-linecap="round" stroke-linejoin="round" d="M12 4v16m8-8H4" />
                  </svg>
                </div>
              </div>
            </summary>

            <div class="faq-content overflow-hidden">
              <div class="px-6 pb-6 pt-2">
                <p class="leading-relaxed text-neutral-600">
                  {faq.answer}
                </p>
              </div>
            </div>
          </details>
        ))}
      </div>
    </div>
  </div>
</section>

<style>
  .faq-item {
    box-shadow: 0 10px 30px rgba(23, 23, 23, 0.04);
  }

  .faq-item:hover {
    border-color: rgba(201, 105, 73, 0.28);
    box-shadow: 0 14px 34px rgba(201, 105, 73, 0.09);
  }

  .faq-item[open] {
    border-color: rgba(201, 105, 73, 0.35);
    box-shadow: 0 18px 36px rgba(201, 105, 73, 0.12);
  }

  .faq-content {
    display: grid;
    grid-template-rows: 0fr;
    transition: grid-template-rows 400ms cubic-bezier(0.4, 0, 0.2, 1);
  }

  .faq-item[open] .faq-content {
    grid-template-rows: 1fr;
  }

  .faq-content > div {
    overflow: hidden;
  }

  .icon-plus {
    transform-origin: center;
  }

  .group:hover .icon-plus {
    transform: scale(1.1);
  }

  .group[open] .icon-plus {
    transform: rotate(45deg);
  }
</style>

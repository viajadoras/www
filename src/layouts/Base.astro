---
import StructuredData from "../components/StructuredData.astro";
import FAQSchema from "../components/FAQSchema.astro";
import IconInstagram from "../components/IconInstagram.astro";
import { company, instagramUrl } from "../data/site";

interface BaseProps {
  title?: string;
  description?: string;
  lang?: string;
  noindex?: boolean;
  structuredDataType?: "homepage" | "page";
  ogImage?: string;
}

const props = Astro.props as BaseProps;
const pageTitle = props.title ?? "Viajadoras | Companhia confiável para sair mais da rotina";
const pageDescription =
  props.description ??
  "Comunidade entre mulheres com grupos, conversa e mais contexto para sair mais na sua cidade e viajar com mais confiança.";
const lang = props.lang ?? "pt-BR";
const noindex = props.noindex ?? false;
const isHomepage = Astro.url.pathname === '/';
const structuredDataType = props.structuredDataType ?? (isHomepage ? "homepage" : "page");
const canonicalBase = Astro.site ?? Astro.url;
const canonicalUrl = canonicalBase
  ? new URL(Astro.url.pathname, canonicalBase).toString()
  : "";
const robotsContent = noindex
  ? "noindex, nofollow, noarchive"
  : "index, follow, max-image-preview:large";

const OG_VERSION = '20251002';
const ogPath = props.ogImage ?? `/og.jpg?v=${OG_VERSION}`;
const ogImage = (Astro.site ? new URL(ogPath, Astro.site).toString() : ogPath);
const ogImageWidePath = `/og_1200x630.jpg?v=${OG_VERSION}`;
const ogImageWide = (Astro.site ? new URL(ogImageWidePath, Astro.site).toString() : ogImageWidePath);
const twitterImagePath = `/twitter_1200x600.jpg?v=${OG_VERSION}`;
const twitterImage = (Astro.site ? new URL(twitterImagePath, Astro.site).toString() : twitterImagePath);
const ogAlt = 'Mulheres compartilhando uma experiência juntas — Viajadoras';

import "../styles/global.css";
---
<!DOCTYPE html>
<html lang={lang}>
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />

    <!-- Primary Meta Tags -->
    <title>{pageTitle}</title>
    <meta name="title" content={pageTitle} />
    <meta name="description" content={pageDescription} />
    <meta name="author" content="Viajadoras" />
    <meta name="robots" content={robotsContent} />
    <meta name="theme-color" content="#C96949" />
    <meta name="color-scheme" content="light" />

    <!-- Preconnect to external domains for better performance -->
    <link rel="preconnect" href="https://www.googletagmanager.com" />
    <link rel="preconnect" href="https://plausible.io" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />

    <!-- Google Fonts -->
    <link href="https://fonts.googleapis.com/css2?family=Fraunces:opsz,wght@9..144,500;9..144,600;9..144,700&family=Manrope:wght@400;500;600;700&display=swap" rel="stylesheet" />
    <link href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined" rel="stylesheet" />

    <!-- Favicons -->
    <link rel="icon" type="image/png" href="/logo.png" />
    <link rel="apple-touch-icon" href="/logo.png" />
    <link rel="manifest" href="/manifest.json" />

    <link rel="canonical" href={canonicalUrl} />
    <meta property="og:title" content={pageTitle} />
    <meta property="og:description" content={pageDescription} />
    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonicalUrl} />
    <meta property="og:site_name" content="Viajadoras" />
    <meta property="og:locale" content="pt_BR" />
    <!-- Square image (fallback) -->
    <meta property="og:image" content={ogImage} />
    <meta property="og:image:secure_url" content={ogImage} />
    <meta property="og:image:type" content="image/jpeg" />
    <meta property="og:image:width" content="1024" />
    <meta property="og:image:height" content="1024" />
    <meta property="og:image:alt" content={ogAlt} />
    <!-- Wide image (recommended for Facebook/LinkedIn) -->
    <meta property="og:image" content={ogImageWide} />
    <meta property="og:image:secure_url" content={ogImageWide} />
    <meta property="og:image:type" content="image/jpeg" />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta property="og:image:alt" content={ogAlt} />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={pageTitle} />
    <meta name="twitter:description" content={pageDescription} />
    <meta name="twitter:image" content={twitterImage} />
    <meta name="twitter:image:alt" content={ogAlt} />
    <meta name="twitter:site" content="@viajadorasbr" />
    <meta name="twitter:url" content={canonicalUrl} />

    <!-- Google tag (gtag.js) - Google Ads -->
    <script defer src="https://www.googletagmanager.com/gtag/js?id=AW-17592059630"></script>
    <script defer>
      window.dataLayer = window.dataLayer || [];
      function gtag(){dataLayer.push(arguments);}
      gtag('js', new Date());
      gtag('config', 'AW-17592059630');
    </script>

    <!-- Plausible Analytics -->
    <script defer data-domain="viajadoras.com" src="https://plausible.io/js/script.js"></script>

    <!-- Structured Data (Schema.org) -->
    <StructuredData
      type={structuredDataType}
      title={pageTitle}
      description={pageDescription}
      url={canonicalUrl}
    />
    {isHomepage && <FAQSchema />}
  </head>
  <body class="bg-neutral-50 text-neutral-900 font-sans antialiased">
    <header class="sticky top-0 z-50 w-full border-b border-primary/10 bg-[#F4EBE3]/95 backdrop-blur-sm">
      <div class="container mx-auto px-4 sm:px-6 lg:px-8">
        <div class="flex h-16 items-center justify-between sm:h-[4.5rem]">
          <a href="/" class="flex items-center gap-2.5 sm:gap-3">
            <div class="relative flex h-11 w-11 items-center justify-center sm:h-12 sm:w-12">
              <div class="absolute inset-0 rounded-full bg-[#DEC0AA] shadow-[0_8px_18px_rgba(23,23,23,0.08)]"></div>
              <img src="/logo.png" alt="Viajadoras" width="44" height="44" class="relative z-10 h-10 w-10 object-contain [filter:drop-shadow(0_1px_1px_rgba(23,23,23,0.16))_drop-shadow(0_4px_12px_rgba(23,23,23,0.10))] sm:h-11 sm:w-11" />
            </div>
            <div class="flex flex-col">
              <h2 class="font-display text-[1.55rem] font-semibold text-neutral-900 tracking-tight sm:text-[1.75rem]">Viajadoras</h2>
            </div>
          </a>
          <nav class="hidden lg:flex items-center gap-1">
            <a class="relative px-4 py-2 text-sm font-medium text-neutral-700 hover:text-neutral-900 transition-colors group" href="/#o-que-e">
              Como Funciona
              <span class="absolute bottom-0 left-1/2 -translate-x-1/2 w-0 h-0.5 bg-gradient-to-r from-primary to-secondary group-hover:w-full transition-all duration-300"></span>
            </a>
            <a class="relative px-4 py-2 text-sm font-medium text-neutral-700 hover:text-neutral-900 transition-colors group" href="/#para-quem">
              Para Quem
              <span class="absolute bottom-0 left-1/2 -translate-x-1/2 w-0 h-0.5 bg-gradient-to-r from-primary to-secondary group-hover:w-full transition-all duration-300"></span>
            </a>
            <a class="relative px-4 py-2 text-sm font-medium text-neutral-700 hover:text-neutral-900 transition-colors group" href="/#faq">
              FAQ
              <span class="absolute bottom-0 left-1/2 -translate-x-1/2 w-0 h-0.5 bg-gradient-to-r from-primary to-secondary group-hover:w-full transition-all duration-300"></span>
            </a>
          </nav>
          <div class="flex items-center gap-3 sm:gap-4">
            <a
              href="/#baixar"
              class="hidden rounded-full bg-primary px-4 py-2 text-sm font-semibold text-white transition hover:bg-primary-600 sm:inline-flex"
            >
              <span>Baixar o app</span>
            </a>
            <a
              href="/#baixar"
              class="rounded-full bg-primary px-3 py-2 text-sm font-semibold text-white transition hover:bg-primary-600 lg:hidden"
              aria-label="Baixar o app"
            >
              Baixar
            </a>
          </div>
        </div>
      </div>
    </header>
    <main>
      <slot />
    </main>
    <footer class="bg-neutral-900 py-16 text-neutral-100">
      <div class="container relative z-10 mx-auto px-4 sm:px-6 lg:px-8">
        <div class="grid grid-cols-1 gap-10 md:grid-cols-[1.3fr_1fr_1fr_0.8fr]">
          <div>
            <h3 class="text-lg font-bold text-white">Viajadoras</h3>
            <p class="mt-2 text-sm leading-6 text-neutral-400">Grupos entre mulheres para sair mais da rotina e viajar com mais confiança.</p>
          </div>
          <div>
            <h3 class="font-semibold uppercase tracking-wider text-white text-sm">Site</h3>
            <nav class="mt-4 flex flex-col gap-2">
              <a class="text-neutral-400 hover:text-primary transition-colors text-sm" href="/#o-que-e">Como funciona</a>
              <a class="text-neutral-400 hover:text-primary transition-colors text-sm" href="/#para-quem">Para quem</a>
              <a class="text-neutral-400 hover:text-primary transition-colors text-sm" href="/#faq">FAQ</a>
              <a class="text-neutral-400 hover:text-primary transition-colors text-sm" href="/#baixar">Baixar o app</a>
            </nav>
          </div>
          <div>
            <h3 class="font-semibold uppercase tracking-wider text-white text-sm">Guias</h3>
            <nav class="mt-4 flex flex-col gap-2">
              <a class="text-neutral-400 hover:text-primary transition-colors text-sm" href="/viajar-sozinha-mulher">Viajar sozinha</a>
              <a class="text-neutral-400 hover:text-primary transition-colors text-sm" href="/viagens-para-mulheres">Viagens para mulheres</a>
              <a class="text-neutral-400 hover:text-primary transition-colors text-sm" href="/companhia-para-viajar">Companhia para viajar</a>
              <a class="text-neutral-400 hover:text-primary transition-colors text-sm" href="/companhia-feminina-para-sair">Companhia feminina para sair</a>
            </nav>
          </div>
          <div>
            <h3 class="font-semibold uppercase tracking-wider text-white text-sm">Legal e redes</h3>
            <nav class="mt-4 flex flex-col gap-2">
              <a class="text-neutral-400 hover:text-primary transition-colors text-sm" href="/termos">Termos de Uso</a>
              <a class="text-neutral-400 hover:text-primary transition-colors text-sm" href="/privacidade">Privacidade</a>
              <a class="text-neutral-400 hover:text-primary transition-colors text-sm" href={instagramUrl} target="_blank" rel="noopener noreferrer">Instagram</a>
            </nav>
            <div class="mt-4">
              <a class="inline-flex h-10 w-10 items-center justify-center rounded-full bg-neutral-800 text-neutral-400 transition-all hover:bg-primary hover:text-white" href={instagramUrl} target="_blank" rel="noopener noreferrer" aria-label="Instagram">
                <IconInstagram class="h-5 w-5" />
              </a>
            </div>
          </div>
        </div>
        <div class="mt-12 border-t border-neutral-800 pt-8 text-center text-sm text-neutral-500">
          <p>© {new Date().getFullYear()} Viajadoras. Todos os direitos reservados.</p>
          <p class="mt-2">{company.legalName} · CNPJ {company.cnpj}</p>
        </div>
      </div>
    </footer>
    <script>
      // Global Scroll Reveal Observer (unified — handles .scroll-reveal + optional data-delay)
      function initScrollReveal() {
        const observer = new IntersectionObserver((entries, obs) => {
          entries.forEach(entry => {
            if (entry.isIntersecting) {
              const delay = parseInt(entry.target.getAttribute('data-delay') || '0', 10);
              if (delay > 0) {
                setTimeout(() => entry.target.classList.add('revealed'), delay);
              } else {
                entry.target.classList.add('revealed');
              }
              obs.unobserve(entry.target);
            }
          });
        }, { threshold: 0.15, rootMargin: '0px 0px -50px 0px' });

        document.querySelectorAll('.scroll-reveal').forEach(el => observer.observe(el));
      }

      if (document.readyState === 'loading') {
        document.addEventListener('DOMContentLoaded', initScrollReveal);
      } else {
        initScrollReveal();
      }

      // Re-initialize on Astro page transitions
      document.addEventListener('astro:page-load', initScrollReveal);
    </script>
  </body>

</html>
